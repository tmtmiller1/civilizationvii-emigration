{
  "// Dev-only": "Type-checks the shipped .js via JSDoc. Emits nothing. Excluded from release.sh.",
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "/emigration/*": ["./*"],
      "/core/*": ["./types/engine-core-stub.d.ts"],
      "/base-standard/*": ["./types/engine-core-stub.d.ts"]
    },
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": []
  },
  "include": ["ui/**/*.js", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "ui/migration-probe.js"]
}
